{
  "productName": "Belt Mod Manager",
  "version": "0.9.6",
  "identifier": "com.belt.modmanager",
  "build": {
    "beforeDevCommand": "node backend/build-css-conditional.js",
    "beforeBuildCommand": "node backend/build-css-conditional.js",
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "publisher": "Kraid"
  }
}
