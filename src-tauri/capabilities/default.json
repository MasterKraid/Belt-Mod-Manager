{
  "$schema": "../node_modules/@tauri-apps/cli/schema/capability.json",
  "identifier": "default-capability",
  "description": "Default capabilities for Factorio Mod Manager",
  "windows": ["main"],
  "permissions": [
    "core:event:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bun",
          "cmd": "bun",
          "args": ["backend/server.js"]
        },
        {
          "name": "node",
          "cmd": "node",
          "args": ["backend/server.js"]
        }
      ]
    }
  ]
}
