<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Factorio Mod Manager</title>
  <link rel="stylesheet" href="/styles/main.css">
  <script src="https://cdn.jsdelivr.net/npm/vue@2"></script>
</head>
<body>
  <div id="app" class="container">
    <h1>Factorio Mod Manager</h1>
    <p>{{ status }}</p>

    <div class="controls">
      <button @click="toggleAll(true)">Enable All</button>
      <button @click="toggleAll(false)">Disable All</button>
      <button @click="saveMods">Save</button>
    </div>

    <div class="mod-list">
      <div class="mod-item" v-for="mod in mods" :key="mod.name">
        <div>
          <strong>{{ mod.title }}</strong> <small>({{ mod.name }})</small>
          <div class="version">v{{ mod.version }}</div>
        </div>
        <input type="checkbox" v-model="mod.enabled">
      </div>
    </div>
  </div>

  <script src="/scripts/main.js"></script>
</body>
</html>
