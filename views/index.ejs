                        <polyline points="17 11 12 16 7 11"></polyline>
                        <line x1="12" y1="9" x2="12" y2="16"></line>
                        <path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"></path>
                      </svg>
                      Update to v{{ modUpdates[mod.name] }}
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Placeholder Tabs -->
