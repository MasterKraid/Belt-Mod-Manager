                    <span class="dl-result-version" v-if="mod.latest_release">v{{ mod.latest_release.version }}</span>
                    <span class="dl-result-installed" v-if="mod.installed">INSTALLED</span>
                  </div>
                  <div class="dl-result-meta">
                    <span>by {{ mod.owner }}</span>
                    <span class="dl-dot"></span>
                    <span>{{ formatDownloads(mod.downloads_count) }} downloads</span>
                    <span class="dl-dot" v-if="mod.category"></span>
                    <span v-if="mod.category">{{ mod.category }}</span>
                  </div>
                  <div class="dl-result-summary">{{ mod.summary }}</div>
                </div>
              </div>
              <div class="dl-result-actions">
                <button class="dl-btn dl-btn-primary has-tooltip" @click="downloadMod(mod)"
                  :disabled="!mod.latest_release || isGameRunning || isModDownloading(mod.name)"
                  :data-tooltip="isModDownloading(mod.name) ? 'Downloading...' : (mod.installed ? 'Already downloaded! Update?' : 'Download latest version')">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                </button>
                <button class="dl-btn dl-btn-deps has-tooltip" @click="downloadModWithDeps(mod)"
                  :disabled="!mod.latest_release || isGameRunning || isModDownloading(mod.name)"
                  data-tooltip="Download with all dependencies">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                  +deps
                </button>
              </div>
            </div>
          </div>

          <!-- Empty state -->
          <div v-if="!portalLoading && portalResults.length === 0 && portalSearched"
            class="dl-empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round" class="opacity-muted-heavy">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <p>No mods found. Try a different search term.</p>
          </div>

          <!-- Initial state -->
          <div v-if="!portalSearched && !portalLoading && portalResults.length === 0"
            class="dl-empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round" class="opacity-muted-heavy">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <p>Search the Factorio Mod Portal to find and download mods.</p>
            <p class="dl-empty-state-footnote">Downloads are sourced from re146.dev mirror — no login required.</p>
          </div>

          <!-- Pagination / Bottom Status Row -->
          <div v-if="portalResults.length > 0" class="dl-pagination dl-pagination-layout">
            <div v-if="portalPagination.pageCount > 1" class="dl-pagination-buttons-row">
              <button @click="portalSearch(portalPagination.page - 1)" :disabled="portalPagination.page <= 1"
                class="dl-page-btn">&laquo;</button>
              <span class="dl-page-info">Page {{ portalPagination.page }} of {{ portalPagination.pageCount }}</span>
              <button @click="portalSearch(portalPagination.page + 1)"
                :disabled="portalPagination.page >= portalPagination.pageCount" class="dl-page-btn">&raquo;</button>
            </div>
            
            <!-- Auth status indicator moved to bottom right -->
            <span class="dl-auth-indicator dl-auth-indicator-corner has-tooltip" v-if="portalAuth.authenticated" :data-tooltip="'Logged in as ' + portalAuth.username">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#4CAF50" stroke="none"><circle cx="12" cy="12" r="10"/></svg>
              {{ portalAuth.username }}
            </span>
            <span class="dl-auth-indicator dl-auth-mirror dl-auth-indicator-corner has-tooltip" v-else data-tooltip="Sign in to Factorio to use Official Mod Portal">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#f4a261" stroke="none"><circle cx="12" cy="12" r="10"/></svg>
              re146.dev mirror
            </span>
          </div>

          <!-- Active Downloads Panel -->
          <div v-if="activeDownloads.length > 0" class="dl-downloads-panel">
            <div class="dl-downloads-header">
              <h4 class="dl-downloads-header-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round" class="vertical-align-icon-text">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Downloads
              </h4>
              <button class="dl-btn-clear has-tooltip" @click="clearDownloads" data-tooltip="Clear completed">Clear</button>
            </div>
            <div class="dl-downloads-list">
              <div class="dl-download-item" v-for="dl in activeDownloads" :key="dl.id"
                :class="'dl-status-' + dl.status">
                <div class="dl-download-icon">
                  <svg v-if="dl.status === 'downloading' || dl.status === 'queued'" width="16" height="16"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                  <svg v-else-if="dl.status === 'complete'" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="#4CAF50" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <svg v-else-if="dl.status === 'retrying'" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="#FFA500" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="23 4 23 10 17 10"></polyline>
                    <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                  </svg>
                  <svg v-else-if="dl.status === 'failed'" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="#F44336" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                  <svg v-else width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="#888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                  </svg>
                </div>
                <div class="dl-download-info">
                  <div class="dl-download-name">{{ dl.fileName }}</div>
                  <div class="dl-download-progress-row" v-if="dl.status === 'downloading'">
                    <div class="dl-progress-bar">
                      <div class="dl-progress-fill" :style="{ width: (dl.progress * 100) + '%' }"></div>
                    </div>
                    <span class="dl-progress-text">
                      {{ (dl.progress * 100).toFixed(0) }}%
                      <template v-if="dl.speed"> — {{ formatBytes(dl.speed) }}/s</template>
                    </span>
                  </div>
                  <div class="dl-download-sub" v-else-if="dl.status === 'complete' && dl.skipped">Already installed</div>
                  <div class="dl-download-sub" v-else-if="dl.status === 'complete'">Completed</div>
                  <div class="dl-download-sub" v-else-if="dl.status === 'queued'">Queued...</div>
                  <div class="dl-download-sub" v-else-if="dl.status === 'retrying'">Retrying ({{ dl.retryCount }}/3)...</div>
                  <div class="dl-download-sub dl-error-text" v-else-if="dl.status === 'failed'">{{ dl.error }}</div>
                  <div class="dl-download-sub" v-else-if="dl.status === 'cancelled'">Cancelled</div>
                </div>
                <button v-if="dl.status === 'downloading' || dl.status === 'queued'"
                  class="dl-cancel-btn has-tooltip" @click="cancelDownload(dl.id)" data-tooltip="Cancel">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="app-footer">
        <button class="exit-btn" @click="closeWindow">Exit</button>
        <div class="drag-ridges"></div>
      </div>

      <!-- Auth Popup Modal -->
      <div v-if="showAuthPopup" class="dl-modal-overlay" @click.self="showAuthPopup = false">
        <div class="dl-modal">
          <div class="dl-modal-header">
            <h3>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round" class="dl-modal-header-icon">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              Factorio Credentials
            </h3>
            <button class="dl-modal-close" @click="showAuthPopup = false; playSound('click')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>

          <div class="dl-modal-body">
            <p class="dl-modal-desc" v-if="!portalAuth.authenticated">
              Enter your Factorio account <strong>username</strong> and <strong>password</strong> to
              authenticate directly with Factorio servers. This enables downloading
              from the official mod portal.
            </p>
            <p class="dl-modal-desc dl-auth-active" v-else>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              Authenticated as <strong>{{ portalAuth.username }}</strong>. Downloads use the official Factorio mod portal.
            </p>

            <p v-if="authError" class="dl-auth-error">{{ authError }}</p>
            <div v-if="!portalAuth.authenticated" class="dl-form-group">
              <label>Username</label>
              <input type="text" v-model="authUsername" placeholder="Your Factorio username" class="dl-form-input"
                @keyup.enter="$event.target.nextElementSibling && $event.target.parentElement.nextElementSibling.querySelector('input').focus()" />
            </div>
            <div v-if="!portalAuth.authenticated" class="dl-form-group">
              <label>Password</label>
              <input type="password" v-model="authPassword" placeholder="Your Factorio password" class="dl-form-input"
                @keyup.enter="saveAuthCredentials" />
            </div>

            <div class="dl-modal-actions">
              <button v-if="!portalAuth.authenticated" class="dl-btn dl-btn-primary"
                @click="saveAuthCredentials" :disabled="!authUsername || !authPassword || authLoading">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                  <polyline points="17 21 17 13 7 13 7 21"></polyline>
                  <polyline points="7 3 7 8 15 8"></polyline>
                </svg>
                {{ authLoading ? 'Authenticating...' : 'Login & Save' }}
              </button>
              <button v-if="portalAuth.authenticated" class="dl-btn dl-btn-danger"
                @click="clearAuthCredentials">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="3 6 5 6 21 6"></polyline>
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
                Remove Credentials
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Mod Settings Popup Modal -->
      <div v-if="showModSettingsPopup" class="dl-modal-overlay" @click.self="showModSettingsPopup = false">
        <div class="dl-modal">
          <div class="dl-modal-header">
            <h3>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round" class="dl-modal-header-icon">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
              </svg>
              Settings: {{ selectedSettingsMod ? selectedSettingsMod.title : '' }}
            </h3>
            <button class="dl-modal-close" @click="showModSettingsPopup = false; playSound('click')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>

          <div class="dl-modal-body">
            <div class="dl-empty-state">
              <p>Coming soon...</p>
            </div>
          </div>
        </div>
      </div>


    </div>
  </div>


  <script>
    // Polyfill window.electronAPI under Tauri so all frontend folder picking, external URLs,
    // and window controls work seamlessly and unmodified!
    if (window.__TAURI__) {
      // Use direct safe references to avoid any destructuring or scope errors
      const tauriWebview = window.__TAURI__.webviewWindow;
      const tauriDialog = window.__TAURI__.dialog;
      const tauriShell = window.__TAURI__.shell;

      window.electronAPI = {
        selectFolder: async () => {
          try {
            if (tauriDialog && tauriDialog.open) {
              const selected = await tauriDialog.open({
                directory: true,
                multiple: false,
                title: "Select Folder"
              });
              return selected || null;
            }
            return null;
          } catch (err) {
            console.error("Folder selection failed:", err);
            return null;
          }
        },
        openExternal: async (url) => {
          try {
            if (tauriShell && tauriShell.open) {
              await tauriShell.open(url);
            }
          } catch (err) {
            console.error("Failed to open external link:", err);
          }
        },
        minimizeWindow: () => {
          try {
            if (tauriWebview && tauriWebview.getCurrentWebviewWindow) {
              tauriWebview.getCurrentWebviewWindow().minimize();
            }
          } catch (err) {
            console.error("Minimize failed:", err);
          }
        },
        maximizeWindow: () => {
          try {
            if (tauriWebview && tauriWebview.getCurrentWebviewWindow) {
              const win = tauriWebview.getCurrentWebviewWindow();
              win.isMaximized().then(max => {
                if (max) win.unmaximize();
                else win.maximize();
              });
            }
          } catch (err) {
            console.error("Maximize failed:", err);
          }
        },
        closeWindow: () => {
          try {
            if (tauriWebview && tauriWebview.getCurrentWebviewWindow) {
              tauriWebview.getCurrentWebviewWindow().close();
            }
          } catch (err) {
            console.error("Close failed:", err);
          }
        }
      };
    }
  </script>

  <script src="/scripts/main.js"></script>
</body>

</html>