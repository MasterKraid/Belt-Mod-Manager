                    </svg>
                    Wipe Downloads History
                  </button>
                  <span class="settings-field-hint-inline">Removes completed or failed download tasks from your downloader tab.</span>
                </div>
              </div>
            </div>

            <!-- Section: Game Launch Settings -->
