<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title>Belt Mod Manager</title>
  <link rel="icon" type="image/png" href="/Assets/Belt.png">
  <link rel="stylesheet" href="/styles/main.css">
  <script src="/js/vue.js"></script>
</head>

<body spellcheck="false">

  <div id="app" v-cloak>
    <div class="glass-container" :class="{ 'animate-bg': enableBackgroundAnimation }">
      <div id="notifications" class="notifications">
        <div class="notif" v-for="note in notifications" :key="note.id">
          {{ note.message }}
          <div class="bar" :style="{ animationDuration: note.duration + 's' }"></div>
        </div>
      </div>

      <!-- Custom Frameless Titlebar -->
      <div class="custom-titlebar">
        <div class="titlebar-drag-region"></div>
        <div class="titlebar-logo-title">
          <img src="/Assets/Belt.png" alt="Logo" class="titlebar-logo">
          <span class="titlebar-title">Belt Mod Manager</span>
        </div>
        <div class="drag-ridges"></div>
        <div class="titlebar-controls">
          <button class="titlebar-btn minimize has-tooltip tooltip-right" @click="minimizeWindow" data-tooltip="Minimize">
            <svg viewBox="0 0 10.2 1" width="10" height="10">
              <rect y="0" width="10.2" height="1"></rect>
            </svg>
          </button>
        </div>
      </div>
      <div class="header-area">
        <div class="header-title-container">
          <img src="/Assets/Belt.png" class="thumbnail header-thumbnail" />
          <h1>Belt Mod Manager <span class="app-version-tag">v0.9.6</span></h1>
        </div>
        <button class="launch-btn" :class="{ running: isGameRunning }" @click="launchGame"
          :disabled="isGameRunning || !gamePath">
          <svg v-if="!isGameRunning" class="launch-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          <svg v-else class="launch-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <rect x="6" y="4" width="4" height="16"></rect>
            <rect x="14" y="4" width="4" height="16"></rect>
          </svg>
          <span>{{ isGameRunning ? 'Game Running...' : 'Run Game' }}</span>
        </button>
      </div>

      <div class="app-content-scrollable scroll-locked-layout">

        <div v-if="isGameRunning" class="running-banner">
          <svg class="warning-icon banner-warning-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
          Factorio is currently running. Editing features are disabled to prevent file conflicts.
        </div>

        <nav class="tabs">
          <div class="tabs-scroll-container">
            <button :class="{active: currentTab==='profiles'}" @click="switchTab('profiles')">Profiles</button>
            <button :class="{active: currentTab==='manager'}" @click="switchTab('manager')">Manager</button>
            <button :class="{active: currentTab==='config'}" @click="switchTab('config')">Config</button>
            <button :class="{active: currentTab==='installed'}" @click="switchTab('installed')">
              Installed Mods
              <span v-if="Object.keys(modUpdates).length > 0" class="tab-update-counter-badge">{{ Object.keys(modUpdates).length }}</span>
            </button>
            <button :class="{active: currentTab==='downloader'}" @click="switchTab('downloader')">Downloader</button>
            <button :class="{active: currentTab==='settings'}" @click="switchTab('settings')">Settings</button>
          </div>

          <!-- Tab bar separator -->
          <span class="tabs-separator"></span>

          <!-- Auth profile button on the far right of the tab bar -->
          <button class="dl-auth-btn tabs-auth-btn has-tooltip tooltip-below" @click="showAuthPopup = true; playSound('click')"
            :class="{ authenticated: portalAuth.authenticated }"
            :data-tooltip="portalAuth.authenticated ? 'Logged in as ' + portalAuth.username : 'Set Factorio credentials'"
            >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </button>
        </nav>

        <p class="status status-line" v-show="status">{{
          status }}</p>

        <div v-show="currentTab==='profiles'" class="tab-content-wrapper">
          <div class="profiles-section-box paths-box">
            <h3 class="paths-title">Paths</h3>

            <div class="path-setting-row-spacer">
              <div class="paths-label">Mods Folder:</div>
              <span class="paths-value">{{ currentModPath || '(default)' }}</span>
              <button @click="setModPath" :disabled="isGameRunning" class="has-tooltip paths-btn" data-tooltip="Set custom Factorio mods folder path">Set Path</button>
            </div>

            <div class="path-setting-row">
              <div class="paths-label">Game Folder:</div>
              <span class="paths-value">{{ gamePath || '(not set)' }}</span>
              <div class="profile-actions-layout">
                <button @click="detectSteamPath" :disabled="isGameRunning" class="steam-detect-btn steam-detect-btn-style has-tooltip"
                  data-tooltip="Auto-detect from Steam">
                  <svg width="24" height="24" viewBox="0 0 32 32" fill="currentColor">
                    <path
                      d="M 22 6 C 18.745659 6 16.09469 8.6041857 16.007812 11.837891 L 12.337891 17.083984 C 12.065931 17.032464 11.786701 17 11.5 17 C 10.551677 17 9.673638 17.297769 8.9472656 17.800781 L 4 15.84375 L 4 21.220703 L 7.1054688 22.449219 C 7.5429388 24.475474 9.3449541 26 11.5 26 C 13.703628 26 15.534282 24.405137 15.917969 22.310547 L 21.691406 17.984375 C 21.794183 17.989633 21.895937 18 22 18 C 25.309 18 28 15.309 28 12 C 28 8.691 25.309 6 22 6 z M 22 8 C 24.206 8 26 9.794 26 12 C 26 14.206 24.206 16 22 16 C 19.794 16 18 14.206 18 12 C 18 9.794 19.794 8 22 8 z M 22 9 A 3 3 0 0 0 22 15 A 3 3 0 0 0 22 9 z M 11.5 18 C 13.43 18 15 19.57 15 21.5 C 15 23.43 13.43 25 11.5 25 C 10.078718 25 8.8581368 24.145398 8.3105469 22.925781 L 10.580078 23.824219 C 10.882078 23.944219 11.192047 24.001953 11.498047 24.001953 C 12.494047 24.001953 13.436219 23.403875 13.824219 22.421875 C 14.333219 21.137875 13.703922 19.683781 12.419922 19.175781 L 10.142578 18.273438 C 10.560118 18.097145 11.019013 18 11.5 18 z" />
                  </svg>
                </button>
                <button @click="setGamePath" :disabled="isGameRunning" class="has-tooltip btn-set-game-path" data-tooltip="Set custom Factorio game folder path">Set Game Path</button>
              </div>
            </div>
          </div>

          <div class="profiles-section-box flex-fill profiles-section-reset-mt">
            <div class="profiles-list-titlebar">
              <h3 class="profiles-list-title">Profiles</h3>
              <div class="search-wrapper search-wrapper-mini">
                <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" v-model="profileSearchQueryPage" placeholder="Search profiles..."
                  class="custom-search-input" />
                <button v-if="profileSearchQueryPage" class="search-clear-btn" @click="profileSearchQueryPage = ''; playSound('click')">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </button>
              </div>
            </div>
            <div class="profile-list scrollable-list-box"
              :style="{ pointerEvents: isGameRunning ? 'none' : 'auto', opacity: isGameRunning ? 0.6 : 1 }">
              <div class="mod-item profile-item" v-for="p in filteredProfilesList" :key="p" @click="activateProfile(p)">
                <div class="profile-name profile-name-container">
                  <input v-if="editingProfile === p" v-model="renameInput" ref="renameInputRef"
                    @keyup.enter="submitRename(p)" @keyup.esc="cancelRename" @click.stop
                    class="profile-edit-input-field" />
                  <strong v-else>{{ p }}</strong>
                </div>
                <div class="profile-actions-layout" @click.stop>
                  <!-- Editing Prompts -->
                  <div v-if="editingProfile === p" class="profile-edit-actions-cluster">
                    <button @click.stop="submitRename(p)" class="btn-profile-rename-accept">Accept</button>
                    <button @click.stop="cancelRename" class="btn-profile-mini-cancel">Cancel</button>
                  </div>

                  <!-- Two-Step Delete Prompts -->
                  <div v-else-if="deletingProfileName === p" class="profile-delete-actions-cluster">
                    <button @click.stop="confirmDeleteProfile(p)" class="btn-profile-delete-trigger">Delete?</button>
                    <button @click.stop="deletingProfileName = null; playSound('click')" class="btn-profile-mini-cancel">Cancel</button>
                  </div>

                  <template v-else>
                    <span v-if="p !== 'default'" @click.stop="deletingProfileName = p; playSound('click')" class="has-tooltip profile-delete-svg-btn" data-tooltip="Delete Profile">
                      <svg class="profile-delete-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none"
                        stroke="#d62246" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        <line x1="10" y1="11" x2="10" y2="17"></line>
                        <line x1="14" y1="11" x2="14" y2="17"></line>
                      </svg>
                    </span>
                    <span class="pencil has-tooltip" @click.stop="startRename(p)" data-tooltip="Rename Profile">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16">
                        <path
                          d="M4 21v-3.586l11.293-11.293 3.586 3.586L7.586 21H4zm14.707-14.707l-1.414-1.414a1 1 0 00-1.414 0l-1.293 1.293 3.586 3.586 1.293-1.293a1 1 0 000-1.414z" />
                      </svg>
                    </span>
                  </template>
                  <label v-if="editingProfile !== p && deletingProfileName !== p" class="switch switch-label-spacing">
                    <input type="checkbox" :checked="p === selectedProfile" @change="activateProfile(p)"
                      :disabled="isGameRunning">
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
            </div>
            <button @click="createProfile" :disabled="isGameRunning" class="btn-profile-create-placement">New Profile</button>
          </div>
        </div>

        <div v-show="currentTab==='manager'" class="tab-content-wrapper">
          <div class="active-profile-row manager-active-profile-row">
            <h3 class="manager-active-profile-row-heading">Active Profile:</h3>
            <div class="custom-dropdown" :class="{ disabled: isGameRunning }">
              <div class="dropdown-trigger" @click.stop="toggleDropdown">
                <span class="profile-highlight">{{ selectedProfile }}</span>
                <svg class="dropdown-arrow" :class="{ open: dropdownOpen }" width="18" height="18" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </div>
              <div v-show="dropdownOpen" class="dropdown-menu">
                <div v-if="profiles.length >= 10" class="dropdown-search-wrapper" @click.stop>
                  <input type="text" v-model="profileSearchQuery" placeholder="Search profiles..."
                    class="dropdown-search-input" ref="profileSearch" />
                </div>
                <div class="dropdown-items-list dropdown-items-scroll">
                  <div v-for="p in filteredDropdownProfiles" :key="p" class="dropdown-item"
                    :class="{ active: p === selectedProfile }" @click.stop="activateProfileFromDropdown(p)">
                    <svg v-if="p === selectedProfile" class="check-icon" width="14" height="14" viewBox="0 0 24 24"
                      fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span>{{ p }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="profiles-section-box flex-fill manager-section-margin">
            <div class="manager-controls-row manager-controls-layout">
              <div class="btn-group btn-group-row-alignment">
                <button @click="toggleAll(true)" :disabled="isGameRunning">Enable All</button>
                <button @click="toggleAll(false)" :disabled="isGameRunning">Disable All</button>
                <button @click="saveMods" :disabled="isGameRunning">Save</button>
              </div>

              <div class="manager-search-and-folders">
                <button class="folder-open-btn has-tooltip btn-icon-square-layout" @click="openModFolder" data-tooltip="Open Mods Folder">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                  </svg>
                </button>
                <div class="search-wrapper search-wrapper-manager">
                  <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                  </svg>
                  <input type="text" v-model="searchQueryManager" placeholder="Search mods..."
                    class="custom-search-input" />
                  <button v-if="searchQueryManager" class="search-clear-btn" @click="searchQueryManager = ''; playSound('click')">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                      stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </button>
                </div>
              </div>
            </div>

            <div class="mod-list scrollable-list-box" :style="{ opacity: isGameRunning ? 0.75 : 1 }">
              <div class="mod-item" :class="{ 'has-missing-deps': getMissingDependencies(mod).length > 0 }" v-for="mod in filteredMods" :key="mod.name">
                <div class="mod-info-container mod-info-middle-layout">
                  <img v-if="mod.thumbnail" :src="mod.thumbnail" class="thumbnail manager-thumbnail manager-mod-thumbnail"
                    :class="{ 'base-mod-logo': mod.name === 'base' }" />
                  <div class="mod-meta">
                    <strong>{{ mod.title }}</strong> <small>({{ mod.name }})</small>
                    <div class="version">v{{ mod.version }}</div>
                    <div v-if="getMissingDependencies(mod).length > 0" class="missing-deps-label">
                      Missing: {{ getMissingDependencies(mod).join(', ') }}
                    </div>
                  </div>
                </div>
                
                <div class="mod-actions-flex">
                  <button v-if="getMissingDependencies(mod).length > 0"
                    class="queue-missing-deps-btn has-tooltip"
                    :data-tooltip="'Queue downloading missing required dependencies: ' + getMissingDependencies(mod).join(', ')"
                    @click.stop="downloadDependencies(mod)">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                    Install Deps
                  </button>

                  <label class="switch" :class="{ disabled: isGameRunning || mod.name === 'base' }">
                    <input type="checkbox" v-model="mod.enabled" @change="toggleModStatus(mod)"
                      :disabled="isGameRunning || mod.name === 'base'">
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div v-show="currentTab==='installed'" class="installed-page-container tab-content-wrapper">
          <div class="installed-title-row installed-tab-header-layout">
            <h3 class="installed-tab-title">Installed Mods</h3>

            <div class="installed-tab-controls-cluster">
              <!-- Sorting Dropdown for Installed Mods -->
              <div class="custom-dropdown dl-mini-dropdown installed-sort-dropdown-width" @click.stop>
                <div class="dropdown-trigger has-tooltip" data-tooltip="Sort Installed Mods"
                  @click="installedSortOpen = !installedSortOpen; playSound('click')">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round" class="sort-svg-alignment">
                    <path d="M15 15l-3 3-3-3M12 6v12M9 9l3-3 3 3"></path>
                  </svg>
                  <span class="profile-highlight">
                    {{ 
                      installedSort === 'last-downloaded' ? 'Last Downloaded' : 
                      installedSort === 'update-needed' ? 'Update Needed' : 
                      installedSort === 'enabled-first' ? 'Enabled First' :
                      'Alphabetical' 
                    }}
                  </span>
                  <svg class="dropdown-arrow" :class="{ open: installedSortOpen }" width="14" height="14" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </div>
                <div v-show="installedSortOpen" class="dropdown-menu full-width-dropdown-menu">
                  <div class="dropdown-item" :class="{ active: installedSort === 'name' }"
                    @click="installedSort = 'name'; installedSortOpen = false; playSound('click')">
                    <svg v-if="installedSort === 'name'" class="check-icon" width="12" height="12" viewBox="0 0 24 24"
                      fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>Alphabetical</span>
                  </div>
                  <div class="dropdown-item" :class="{ active: installedSort === 'last-downloaded' }"
                    @click="installedSort = 'last-downloaded'; installedSortOpen = false; playSound('click')">
                    <svg v-if="installedSort === 'last-downloaded'" class="check-icon" width="12" height="12" viewBox="0 0 24 24"
                      fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>Last Downloaded</span>
                  </div>
                  <div class="dropdown-item" :class="{ active: installedSort === 'update-needed' }"
                    @click="installedSort = 'update-needed'; installedSortOpen = false; playSound('click')">
                    <svg v-if="installedSort === 'update-needed'" class="check-icon" width="12" height="12" viewBox="0 0 24 24"
                      fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>Update Needed</span>
                  </div>
                  <div class="dropdown-item" :class="{ active: installedSort === 'enabled-first' }"
                    @click="installedSort = 'enabled-first'; installedSortOpen = false; playSound('click')">
                    <svg v-if="installedSort === 'enabled-first'" class="check-icon" width="12" height="12" viewBox="0 0 24 24"
                      fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>Enabled First</span>
                  </div>
                </div>
              </div>

              <button class="folder-open-btn has-tooltip installed-folder-open-style" @click="openModFolder" data-tooltip="Open Mods Folder">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                </svg>
              </button>
              <div class="search-wrapper search-wrapper-installed">
                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" v-model="searchQueryInstalled" placeholder="Search installed mods..."
                  class="custom-search-input" />
                <button v-if="searchQueryInstalled" class="search-clear-btn" @click="searchQueryInstalled = ''; playSound('click')">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </button>
              </div>
            </div>
          </div>

          <div class="mod-list">
            <div class="mod-item installed-item" v-for="mod in filteredInstalledMods" :key="mod.name + '@' + mod.version">
              <div class="installed-header" @click="toggleExpand(mod.name)">
                <div class="installed-title-area">
                  <img v-if="mod.thumbnail" :src="mod.thumbnail" class="thumbnail installed-mod-thumbnail"
                    :class="{ 'base-mod-logo': mod.name === 'base' }" />
                  <div class="title-meta">
                    <strong>{{ mod.title }}</strong> <small>({{ mod.name }})</small>
                    <div class="version">
                      v{{ mod.version }}
                      <span v-if="modUpdates[mod.name]" class="installed-update-badge">
                        Update to v{{ modUpdates[mod.name] }}
                      </span>
                    </div>
                  </div>
                </div>
                <div class="installed-header-right">
                  <button class="mod-settings-btn has-tooltip" data-tooltip="Mod Settings" @click.stop="openModSettings(mod); playSound('click')">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="3"></circle>
                      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                  </button>
                  <div class="expand-arrow" :class="{ expanded: expandedMods.includes(mod.name) }">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                      stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </div>
                </div>
              </div>

              <div v-show="expandedMods.includes(mod.name)" class="mod-details">
                <p><strong>Author:</strong> {{ mod.author || 'Unknown' }}</p>
                <p><strong>Description:</strong> {{ mod.description || 'No description.' }}</p>
                <p><strong>Dependencies:</strong>
                  <span class="dependency-list">
                    {{ Array.isArray(mod.dependencies) && mod.dependencies.length ? mod.dependencies.join(', ') : 'None'
                    }}
                  </span>
                </p>

                <!-- Two-Step Mod Deletion Options -->
                <div v-if="!['base', 'elevated-rails', 'quality', 'space-age'].includes(mod.name)" class="installed-details-actions-box">
                  
                  <!-- Standard Deletion -->
                  <div>
                    <!-- Confirmation Mode -->
                    <div v-if="deletingInstalledModName === mod.name" class="profile-actions-layout">
                      <span class="delete-warn-text">Delete this mod zip file from disk?</span>
                      <button class="dl-btn dl-btn-danger btn-confirm-delete-action" @click.stop="confirmDeleteInstalledMod(mod.name)">
                        Yes, Delete!
                      </button>
                      <button class="dl-btn dl-btn-deps btn-cancel-delete-action" @click.stop="deletingInstalledModName = null; playSound('click')">
                        Cancel
                      </button>
                    </div>
                    <!-- Trigger Mode -->
                    <div v-else-if="deletingInstalledModDepsName !== mod.name">
                      <button class="dl-btn dl-btn-danger btn-delete-mod-trigger" @click.stop="deletingInstalledModName = mod.name; playSound('click')">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <polyline points="3 6 5 6 21 6"></polyline>
                          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                        Delete Mod
                      </button>
                    </div>
                  </div>

                  <!-- Recursive Dependency Deletion -->
                  <div>
                    <!-- Confirmation Mode -->
                    <div v-if="deletingInstalledModDepsName === mod.name" class="profile-actions-layout">
                      <span class="delete-warn-text">Delete this mod AND all its unused dependencies recursively?</span>
                      <button class="dl-btn dl-btn-danger btn-confirm-delete-action" @click.stop="confirmDeleteInstalledModWithDeps(mod.name)">
                        Yes, Delete Mod + Deps!
                      </button>
                      <button class="dl-btn dl-btn-deps btn-cancel-delete-action" @click.stop="deletingInstalledModDepsName = null; playSound('click')">
                        Cancel
                      </button>
                    </div>
                    <!-- Trigger Mode -->
                    <div v-else-if="deletingInstalledModName !== mod.name">
                      <button class="dl-btn dl-btn-deps btn-delete-mod-deps-trigger" @click.stop="deletingInstalledModDepsName = mod.name; playSound('click')">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <polyline points="3 6 5 6 21 6"></polyline>
                          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                        Delete +deps
                      </button>
                    </div>
                  </div>

                  <!-- Direct Mod Update Trigger -->
                  <div v-if="modUpdates[mod.name]">
                    <button class="dl-btn dl-btn-primary btn-update-mod-trigger" @click.stop="downloadModUpdate(mod.name, modUpdates[mod.name])">
